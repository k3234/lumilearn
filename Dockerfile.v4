# LumiLearn V4 Docker 镜像
# 兼容 Ollama API 格式

FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 复制模型文件和代码
COPY lumilearn_model_v4_skills/best_model/ /app/model/
COPY lumilearn_model.py /app/
COPY lumilearn_api_server.py /app/

# 安装 Python 依赖
RUN pip install --no-cache-dir \
    torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu \
    flask \
    numpy \
    requests

# 设置环境变量
ENV HOST=0.0.0.0
ENV PORT=8000
ENV MODEL_DIR=/app/model
ENV MODEL_NAME=lumilearn-v4-skills
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["python", "lumilearn_api_server.py"]
