# LumiLearn 环境配置文件

# Ollama API 配置
OLLAMA_BASE_URL=http://192.168.2.63:11434
OLLAMA_MODEL=qwen2.5:7b

# SOLO API 配置（如果使用）
SOLO_API_KEY=your_solo_api_key_here

# 数据路径配置
MASTER_DATA_PATH=./lumilearn_master.csv
TRAINING_DATA_PATH=./training_data

# 模型训练配置
BATCH_SIZE=4
LEARNING_RATE=3e-4
MAX_EPOCHS=50

# 日志级别
LOG_LEVEL=INFO

# 项目路径
PROJECT_ROOT=.
